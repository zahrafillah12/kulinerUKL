generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id         Int        @id @default(autoincrement())
  nama       String
  email      String     @unique
  password   String
  role       Role       @default(USER)

  recipes    Recipe[]
  favorites  Favorite[]

  createdAt  DateTime   @default(now())
}

model Category {
  id         Int        @id @default(autoincrement())
  nama       String

  recipes    Recipe[]
}

model Recipe {
  id                 Int        @id @default(autoincrement())
  namaMakanan        String
  daerahAsal         String
  gambar             String
  deskripsi          String
  bahan              String
  langkahPembuatan   String
  durasi             String
  porsi              String

  userId             Int
  kategoriId         Int

  user User @relation(fields: [userId],references: [id],onDelete: Cascade)

  category Category @relation(fields: [kategoriId],references: [id],onDelete: Cascade)

  favorites Favorite[]

  createdAt DateTime @default(now())
}

model Favorite {
  id         Int      @id @default(autoincrement())

  userId     Int
  recipeId   Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  recipe Recipe @relation(fields: [recipeId], references: [id],onDelete: Cascade)

  createdAt DateTime @default(now())
}