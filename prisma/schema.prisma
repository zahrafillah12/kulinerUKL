generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id Int @id @default(autoincrement())

  nama     String
  email    String @unique
  password String
  role     Role   @default(USER)

  recipes   Recipe[]
  favorites Favorite[]

  payments Payment[]

  purchases Purchase[] // <- HARUS ADA

  createdAt DateTime @default(now())
}

model Category {
  id   Int    @id @default(autoincrement())
  nama String

  recipes Recipe[]
}

model Recipe {
 id               Int    @id @default(autoincrement())

  namaMakanan      String
  daerahAsal       String
  gambar           String

  deskripsi        String @db.Text
  bahan            String @db.Text
  langkahPembuatan String @db.Text
  durasi           String
  porsi            String

  isPremium Boolean @default(false)
  harga     Int?    @default(0)

  userId     Int
  kategoriId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  category Category @relation(fields: [kategoriId], references: [id], onDelete: Cascade)

  favorites Favorite[]

  payments Payment[]

  purchases Purchase[] // <- TAMBAHKAN INI

  createdAt DateTime @default(now())
}

model Favorite {
  id Int @id @default(autoincrement())

  userId   Int
  recipeId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Payment {
  id Int @id @default(autoincrement())

  userId   Int
  recipeId Int

  metode String
  jumlah Int

  status String @default("PENDING")

  buktiTransfer String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Purchase {
  id Int @id @default(autoincrement())

  userId   Int
  recipeId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
